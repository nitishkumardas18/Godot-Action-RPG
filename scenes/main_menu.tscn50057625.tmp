[sub_resource type="GDScript" id="GDScript_l6cm7"]
script/source = "# ui_rpg.gd
extends Panel





func _ready() -> void:
	vbox_start.visible = true
	vbox_try.visible   = false
	vbox_play.visible  = false

func _on_start_pressed() -> void:
	get_tree().change_scene_to_file(\"res://scenes/world.tscn\")

func show_game_over() -> void:
	vbox_start.visible = false
	vbox_try.visible   = true
	vbox_play.visible  = false

func show_victory() -> void:
	vbox_start.visible = false
	vbox_try.visible   = false
	vbox_play.visible  = true

func _on_tryagain_pressed() -> void:
	get_tree().change_scene_to_file(\"res://scenes/MainMenu.tscn\")

func _on_playagain_pressed() -> void:
	get_tree().change_scene_to_file(\"res://scenes/world.tscn\")
"

